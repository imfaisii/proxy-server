# ---- Console admin / session ----
# Password for the web console login.
ADMIN_PASSWORD=admin
# Secret used to sign session cookies. deploy.sh auto-generates a strong value.
SESSION_SECRET=change-me

# ---- Postgres ----
POSTGRES_USER=mtproxy
# deploy.sh auto-generates a strong password and syncs it into DATABASE_URL.
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mtproxy
# Console runs on the host network, so it reaches postgres at 127.0.0.1.
DATABASE_URL=postgres://mtproxy:change-me@127.0.0.1:5432/mtproxy

# ---- telemt proxy ----
# Prometheus metrics endpoint exposed by telemt (KPI tiles).
MTG_METRICS_URL=http://127.0.0.1:9090/metrics
# telemt management REST API (campaigns: users + per-user ad-tags + connect links).
TELEMT_API_URL=http://127.0.0.1:9091
# FakeTLS SNI domain the proxy masquerades as.
MTG_DOMAIN=cloudflare.com
# Public port the proxy listens on.
MTG_PORT=443

# ---- Connection collection (privacy) ----
# When true, the console reads host conntrack to show live connections.
# Connection data is live-only and never persisted. Set false to disable.
COLLECT_CONNECTIONS=true

# ---- GeoIP ----
# Path (inside the console container) to the db-ip city mmdb. Optional.
GEOIP_PATH=/app/data/geoip/city.mmdb

# ---- Polling ----
# How often the server polls mtg metrics, in milliseconds.
POLL_INTERVAL_MS=5000

# ---- Cloudflare Tunnel / console domain ----
# Subdomain the console is served at over SSL.
CONSOLE_DOMAIN=console.nodenocode.com
# Cloudflare Tunnel token. Leave empty to disable the tunnel.
TUNNEL_TOKEN=
# Public IPv4 of this server. Optional; auto-detected for the tg:// link.
SERVER_IP=
